<!-- ============================================================
     FICHIER GENERE par project/templates/build_weather_templates.py
     Profil : fog/fog_moderate   |   NE PAS EDITER A LA MAIN
     Source : base_template.xml + table PRESETS du generateur.
     Regenerer : py project/templates/build_weather_templates.py
     ============================================================ -->
<!--
    base_template.xml — Template de base : trajectoire + meteo + 26 fautes.

    Les variantes meteo (brouillard, nuages, pluie, neige, ciel clair) sont
    des XML autonomes generes dans templates/<profil>/ par :
        py project/templates/build_weather_templates.py
    Choisir le XML actif dans project/settings.xml (parametre template_file_name,
    ex: value="rain/rain_heavy.xml").

    Conventions :
      - min/max identiques = valeur fixe
      - min/max differents = TAF sample dans la plage (z3)
      - severity > 0 active une faute, severity = 0 la desactive

    Modele de duree des fautes (T5) :
      - start_pct    : debut application en % de la trajectoire [0, 100]
      - duration_pct : duree de la faute en % de la trajectoire
      - Contrainte z3 : start_pct + duration_pct <= 100 (sinon UNSAT)

    airport_runway : format "ICAO_RWY" (ex: "LFPO_24").
    Liste = LARD/data/runways_db_V2_XPlane.json (259 aeroports, 980 pistes).
-->
<root name="test_case">

    <node name="scenario" nb_instances="1">

        <!-- ===========================================================
             TRAJECTOIRE : timing, distances, vent, OU, piste
             ===========================================================
        -->
        <node name="trajectory">

            <parameter name="fps"                          type="integer" min="12"   max="12"/>

            <parameter name="along_track_distance_start"   type="real"    min="2800" max="3200"/>
            <parameter name="along_track_distance_end"     type="real"    min="280"  max="320"/>
            <parameter name="ground_speed_kts"             type="real"    min="145"  max="145"/>

            <!-- Processus Ornstein-Uhlenbeck (turbulence) -->
            <parameter name="turbulence_intensity"         type="real"    min="0"    max="1"/>

            <!-- Vent -->
            <parameter name="wind_speed_kts"               type="real"    min="0"    max="30"/>
            <parameter name="wind_direction_deg"           type="real"    min="0"    max="359"/>

            <!-- Convergence finale   min="1000" max="1500"/> -->
            <parameter name="stabilization_distance_m"     type="real"    min="1000" max="1500"/>

            <!-- Piste cible (ICAO_RWY) -->
           
            <parameter name="airport_runway"               type="string"  values="CYEG_2;CYEG_20;CYVR_08L;CYVR_08R;CYVR_13;CYVR_26L;CYVR_26R;CYVR_31;CYYC_11;CYYC_17L;CYYC_17R;CYYC_26;CYYC_29;CYYC_35L;CYYC_35R;CYYC_8;CYYZ_06L;CYYZ_06R;CYYZ_15L;CYYZ_15R;CYYZ_24L;CYYZ_24R;CYYZ_33L;CYYZ_33R;DAAG_23;DAAG_27;DAAG_5;DAAG_9;DTTA_1;DTTA_11;DTTA_19;DTTA_29;EBBR_01;EBBR_07L;EBBR_07R;EBBR_19;EBBR_25L;EBBR_25R;EBCI_24;EBCI_6;EDDF_07C;EDDF_07L;EDDF_07R;EDDF_25C;EDDF_25L;EDDF_25R;EDDH_15;EDDH_23;EDDH_33;EDDH_5;EDDK_14L;EDDK_14R;EDDK_24;EDDK_32L;EDDK_32R;EDDK_6;EDDL_05L;EDDL_05R;EDDL_23L;EDDL_23R;EDDM_26L;EDDM_26R;EDDM_8L;EDDM_8R;EDDS_07;EDDS_25;EDDV_27L;EDDV_27R;EDDV_9L;EDDV_9R;EFHK_15;EFHK_22L;EFHK_22R;EFHK_33;EFHK_4L;EFHK_4R;EGAA_25;EGAA_7;EGBB_15;EGBB_33;EGCC_05L;EGCC_05R;EGCC_23L;EGCC_23R;EGGD_27;EGGD_9;EGGW_25;EGGW_7;EGKK_08L;EGKK_08R;EGKK_26L;EGKK_26R;EGLL_27L;EGLL_27R;EGLL_9L;EGLL_9R;EGPF_23;EGPF_5;EGPH_06;EGPH_24;EGSS_04;EGSS_22;EHAM_00C;EHAM_00L;EHAM_04;EHAM_06;EHAM_18C;EHAM_18R;EHAM_22;EHAM_24;EHAM_27;EHAM_9;EHEH_03;EHEH_21;EIDW_10R;EIDW_28L;EKCH_12;EKCH_22L;EKCH_22R;EKCH_30;EKCH_4L;EKCH_4R;ENBR_17;ENBR_35;ENGM_19L;ENGM_19R;ENGM_1L;ENGM_1R;EPKK_07;EPKK_25;EPWA_11;EPWA_15;EPWA_29;EPWA_33;ESSA_01L;ESSA_01R;ESSA_08;ESSA_19L;ESSA_19R;ESSA_26;FACT_01;FACT_16;FACT_19;FACT_34;FALE_24;FALE_6;FAOR_03L;FAOR_03R;FAOR_21L;FAOR_21R;GCLP_03L;GCLP_03R;GCLP_21L;GCLP_21R;GCTS_07;GCTS_25;GMMN_17L;GMMN_17R;GMMN_35L;GMMN_35R;GMMX_10;GMMX_28;HECA_05C;HECA_05L;HECA_05R;HECA_23C;HECA_23L;HECA_23R;KATL_10;KATL_26L;KATL_26R;KATL_27L;KATL_27R;KATL_28;KATL_8L;KATL_8R;KATL_9L;KATL_9R;KAUS_00L;KAUS_00R;KAUS_18L;KAUS_18R;KBDL_15;KBDL_24;KBDL_33;KBDL_6;KBNA_13;KBNA_20C;KBNA_20L;KBNA_20R;KBNA_2C;KBNA_2L;KBNA_2R;KBNA_31;KBOS_15R;KBOS_22L;KBOS_22R;KBOS_27;KBOS_33L;KBOS_4L;KBOS_4R;KBOS_9;KBUR_15;KBUR_26;KBUR_33;KBUR_8;KBWI_15L;KBWI_33R;KCLE_10;KCLE_24L;KCLE_24R;KCLE_28;KCLE_6L;KCLE_6R;KCLT_00C;KCLT_00L;KCLT_00R;KCLT_05;KCLT_18C;KCLT_18L;KCLT_18R;KCLT_23;KCMH_10L;KCMH_10R;KCMH_28L;KCMH_28R;KCVG_00C;KCVG_00