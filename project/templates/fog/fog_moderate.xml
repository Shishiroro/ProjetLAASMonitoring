            <!-- Contraintes trajectoire :
                 1) start > end (sens d'approche)
                 2) stab >= end + 500   (zone de convergence assez large)
                 3) start >= stab + 500 (trajectoire libre OU avant convergence) -->
            <constraint name="dist_order"
                        expressions=".\along_track_distance_start SUP .\along_track_distance_end"/>
            <constraint name="stab_above_end"
                        expressions=".\stabilization_distance_m SUPEQ .\along_track_distance_end + 500"/>
            <constraint name="start_above_stab"
                        expressions=".\along_track_distance_start SUPEQ .\stabilization_distance_m + 500"/>

        </node>


        <!-- ===========================================================
             METEO X-Plane 12 (per-scenario, injectee 1x avant rendu)
             ===========================================================
             COMPORTEMENT :
               - Pluie seule    (precip > 0, cloud_type = -1) : Cumulonimbus auto
               - Nuages seuls   (cloud_type >= 0, precip = 0) : nuages manuels
               - Pluie + nuages (precip > 0, cloud_type >= 0) : nuages manuels
               - Rien           (precip = 0, cloud_type = -1) : pas d'injection

             cloud_type enum : 0=Cirrus, 1=Stratus, 2=Cumulus, 3=Cumulonimbus, -1=auto

             Ce fichier (base_template.xml) garde des valeurs meteo de base.
             Les variantes de profil (brouillard, nuages, pluie, neige, clair)
             sont generees dans templates/<profil>/ par :
                 py project/templates/build_weather_templates.py
             Le generateur remplace UNIQUEMENT les 8 parametres situes entre
             @@WEATHER_BLOCK_START@@ et @@WEATHER_BLOCK_END@@. Le reste
             (weather_effect_duration, node settings) est commun a tous.
        -->
        <node name="weather">

            <!-- @@WEATHER_BLOCK_START@@ -->

            <!-- Precipitation (0 = aucune ; >0 + cloud_type=-1 => Cb auto) -->
            <parameter name="precip_rate"         type="real" min="0" max="0"/>

            <!-- -1=Cb auto, 0=Cirrus, 1=Stratus, 2=Cumulus, 3=Cumulonimbus -->
            <parameter name="cloud_type"          type="real" min="-1" max="-1"/>

            <!-- Couverture nuageuse [0-1] -->
            <parameter name="cloud_coverage"      type="real" min="0" max="0"/>

            <!-- Epaisseur nuage (m) ; 0 => pas de particules -->
            <parameter name="cloud_thickness_m"   type="real" min="0" max="0"/>

            <!-- Visibilite (m) -->
            <parameter name="fog_visibility"      type="real" min="4000" max="10000"/>

            <!-- Temperature (C) ; < 0 => precip basculee en neige -->
            <parameter name="temperature_c"       type="real" min="15" max="15"/>

            <!-- Taille gouttes (visuel) ; ignore si precip=0 -->
            <parameter name="rain_scale"          type="real" min="1" max="1"/>

            <!-- Marge base nuages au-dessus de l'avion (m) -->
            <parameter name="cloud_margin_m"      type="real" min="2000" max="2000"/>

            <!-- @@WEATHER_BLOCK_END@@ -->


            <!-- Param meteo commun a TOUS les profils : jamais remplace par
                 build_weather_templates.py.
                 Délai accumulation effets sol : flaques de pluie / couche de
                 neige. Ignoré si precip_rate=0. Mettre 0 pour de la pluie
                 SANS accumulation. -->
            <parameter name="weather_effect_duration" type="real" min="0"     max="0"/>

        </node>


        <!-- ===========================================================
             SETTINGS : reglages de rendu / sim, communs a tous les profils
             ===========================================================
             Parametres independants de la meteo et des fautes capteur.
             Jamais remplaces par build_weather_templates.py.
        -->
        <node name="settings">

            <!-- Heure du jour locale (conversion UTC via fuseau politique) -->
            <parameter name="time_of_day_h"           type="real" min="12"    max="12"/>

            <!-- Délai chargement textures de la zone + stabilisation nuages GPU
                 (vitesse sim normale). Appliqué à TOUS les scénarios. -->
            <parameter name="load_texture_duration"   type="real" min="5"     max="5"/>

            <!-- Délai stabilisation pose APRES chaque téléportation caméra (s). -->
            <parameter name="screenshot_duration"     type="real" min="0.07"  max="0.07"/>

            <!-- Rayon de la zone meteo injectee dans XPLMWeather (nm ; 1 nm = 1.852 km).
                 Plus le rayon est petit, plus la meteo est concentree localement.
                 Plus il est grand, plus on voit les nuages au loin.
                 Recommendation =50 pour utilisation générale (effets météos constants), ou plusieurs centaines pour effets plus jolis -->
            <parameter name="weather_zone_radius_nm"  type="real" min="50"    max="50"/>

        </node>


        <!-- ===========================================================
             FAUTES CAPTEUR : 26 sub-nodes, params propres a chaque faute
             ===========================================================
             Pour activer une faute :
               1) severity min/max > 0
               2) ajuster start_pct + duration_pct selon le moment souhaite

             Plusieurs fautes se cumulent si leurs plages se chevauchent.
        -->
        <node name="faults">

            <!-- ===== Bruits ===== -->
            <node name="gaussian_noise">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="shot_noise">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="salt_pepper">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="dead_pixels">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Flous ===== -->
            <node name="motion_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="defocus_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <!-- Flou type verre depoli (albumentations.GlassBlur mode 'fast') :
                 permutations locales de pixels + flou gaussien. Simule
                 lentille sale/gelee/condensee. severity 0=leger, 1=fort. -->
            <node name="glass_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="rolling_shutter">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Exposition ===== -->
            <node name="overexposure">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="underexposure">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Optique ===== -->
            <node name="vignetting">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="chromatic_aberration">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="radial_distortion">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="lens_flare">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Artefacts ===== -->
            <node name="banding">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="jpeg_artifacts">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="color_shift">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <!-- Permutation explicite : (c0, c1, c2) = ordre des canaux, c.f. albumentations ChannelShuffle.
                 severity < 0.5 : applique sur BGR natif ; >= 0.5 : applique sur HSV.
                 Contraintes DIF -> c0/c1/c2 forment une vraie permutation (pas de duplication). -->
            <node name="channel_swap">
                <parameter name="severity"     type="real"    min="0"   max="0"/>
                <parameter name="start_pct"    type="real"    min="10"   max="10"/>
                <parameter name="duration_pct" type="real"    min="50" max="50"/>
                <parameter name="c0"           type="integer" min="2"   max="2"/>
                <parameter name="c1"           type="integer" min="1"   max="1"/>
                <parameter name="c2"           type="integer" min="0"   max="0"/>
                <constraint name="bounded"  expressions=".\start_pct + .\duration_pct INFEQ 100"/>
                <constraint name="perm_01"  expressions=".\c0 DIF .\c1"/>
                <constraint name="perm_02"  expressions=".\c0 DIF .\c2"/>
                <constraint name="perm_12"  expressions=".\c1 DIF .\c2"/>
            </node>

            <!-- ===== Salissure / environnement ===== -->
            <node name="condensation">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="dirt_on_lens">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <!-- Gouttelettes / eclaboussures sur la lentille
                 (albumentations.Spatter mode 'rain') : seul gauss_sigma depend
                 de severity (2 -> 5), bcp de gouttelettes -> peu de gouttes-->
            <node name="droplets">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="fog">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <!-- Neige (albumentations.RandomSnow methode bleach) : blanchiment HLS
                 des pixels au-dessus d'un seuil. severity 0=leger, 1=lourd. -->
            <node name="snow">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Transformations geometriques ===== -->
            <node name="zoom_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="contrast">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="pixelate">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

        </node>

    </node>

</root>
