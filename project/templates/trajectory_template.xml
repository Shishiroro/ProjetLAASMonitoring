<?xml version="1.0"?>
<!--

    Conventions :
      - min/max identiques = valeur fixe
      - min/max differents = TAF sample dans la plage (z3)
      - severity > 0 active une faute, severity = 0 la desactive

    Modele de duree des fautes (T5) :
      - start_pct    : debut application en % de la trajectoire [0, 100]
      - duration_pct : duree de la faute en % de la trajectoire
      - Contrainte z3 : start_pct + duration_pct <= 100 (sinon UNSAT)

    airport_runway : format "ICAO_RWY" (ex: "LFPO_06").
    Voir LARD/data/filtered_runways_database_Final.json pour la liste.
-->
<root name="test_case">

    <node name="scenario" nb_instances="1">

        <!-- ===========================================================
             TRAJECTOIRE : timing, distances, vent, OU, piste
             ===========================================================
        -->
        <node name="trajectory">

            <parameter name="fps"                          type="integer" min="10"   max="10"/>

            <parameter name="along_track_distance_start"   type="real"    min="2000" max="2000"/>
            <parameter name="along_track_distance_end"     type="real"    min="280"  max="280"/>
            <parameter name="ground_speed_kts"             type="real"    min="145"  max="145"/>

            <!-- Processus Ornstein-Uhlenbeck (turbulence) -->
            <parameter name="turbulence_intensity"         type="real"    min="0"    max="1"/>

            <!-- Vent -->
            <parameter name="wind_speed_kts"               type="real"    min="0"    max="30"/>
            <parameter name="wind_direction_deg"           type="real"    min="0"    max="359"/>

            <!-- Convergence finale   min="1000" max="1500"/> -->
            <parameter name="stabilization_distance_m"     type="real"    min="1000" max="1500"/>

            <!-- Piste cible (ICAO_RWY) -->
           
            <parameter name="airport_runway"               type="string"  values="KPDX_10L"/>

            <!-- Contraintes trajectoire :
                 1) start > end (sens d'approche)
                 2) stab >= end + 500   (zone de convergence assez large)
                 3) start >= stab + 500 (trajectoire libre OU avant convergence) -->
            <constraint name="dist_order"
                        expressions=".\along_track_distance_start SUP .\along_track_distance_end"/>
            <constraint name="stab_above_end"
                        expressions=".\stabilization_distance_m SUPEQ .\along_track_distance_end + 500"/>
            <constraint name="start_above_stab"
                        expressions=".\along_track_distance_start SUPEQ .\stabilization_distance_m + 500"/>

        </node>


        <!-- ===========================================================
             METEO X-Plane 12 (per-scenario, injectee 1x avant rendu)
             ===========================================================
             COMPORTEMENT :
               - Pluie seule    (precip > 0, cloud_type = -1) : Cumulonimbus auto
               - Nuages seuls   (cloud_type >= 0, precip = 0) : nuages manuels
               - Pluie + nuages (precip > 0, cloud_type >= 0) : nuages manuels
               - Rien           (precip = 0, cloud_type = -1) : pas d'injection

             cloud_type enum : 0=Cirrus, 1=Stratus, 2=Cumulus, 3=Cumulonimbus, -1=auto
        -->
        <node name="weather">

            <!-- Precipitation : 0 = desactive. Cumulonimbus auto si cloud_type=-1. -->
            <parameter name="precip_rate"             type="real" min="1"     max="1"/>

            <!-- cloud_type : -1=auto, 0=Cirrus, 1=Stratus, 2=Cumulus, 3=Cb -->
            <parameter name="cloud_type"              type="real" min="-1"    max="-1"/>
            <parameter name="cloud_coverage"          type="real" min="0.8"   max="0.8"/>

            <!-- Taille gouttes (visuel uniquement, dataref privé XP12(Susceptible d'être cassé dans de futures versions) 
                 1.0=defaut, 0.1=fines, 5.0=grosses. Ignore si precip=0. -->
            <parameter name="rain_scale"              type="real" min="5"     max="5"/>

            <!-- Marge nuages (m) au-dessus de l'avion pour la base nuages -->
            <parameter name="cloud_margin_m"          type="real" min="3000"   max="3000"/>

            <!-- Epaisseur du nuage (alt_top = alt_base + thickness)
                 IMPORTANT : si 0, XPLMWeather cree un nuage degenere (base=top) qui ne
                 genere PAS de particules de pluie/neige. Mettre > 0 pour avoir la pluie.. -->
            <parameter name="cloud_thickness_m"       type="real" min="6000"  max="6000"/>

            <!-- Visibilite (m)  -->
            <parameter name="visibility_m"            type="real" min="30000" max="30000"/>

            <!-- Temperature (°C) :  pluie vs neige -->
            <parameter name="temperature_c"           type="real" min="15"    max="45"/>

            <!-- Heure du jour (locale, conversion UTC approximative) -->
            <parameter name="time_of_day_h"           type="real" min="12"    max="12"/>

            <!-- Délai stabilisation météo/textures avant capture. --> 
            <parameter name="xplane_weather_settle_s" type="real" min="10"    max="10"/>

        </node>


        <!-- ===========================================================
             FAUTES CAPTEUR : 22 sub-nodes, params propres a chaque faute
             ===========================================================
             Pour activer une faute :
               1) severity min/max > 0
               2) ajuster start_pct + duration_pct selon le moment souhaite

             Plusieurs fautes se cumulent si leurs plages se chevauchent.

           Voir différents effets dans le dossier examples.
        -->
        <node name="faults">

            <!-- ===== Bruits ===== -->
            <node name="gaussian_noise">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="shot_noise">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="salt_pepper">
                <parameter name="severity"     type="real" min="1"   max="1"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="10" max="10"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="dead_pixels">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Flous ===== -->
            <node name="motion_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="defocus_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="rolling_shutter">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Exposition ===== -->
            <node name="overexposure">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="underexposure">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Optique ===== -->
            <node name="vignetting">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="chromatic_aberration">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="radial_distortion">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="lens_flare">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Artefacts ===== -->
            <node name="banding">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="jpeg_artifacts">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="color_shift">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Salissure / environnement ===== -->
            <node name="condensation">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="dirt_on_lens">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="fog">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

            <!-- ===== Transformations geometriques ===== -->
            <node name="zoom_blur">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="contrast">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>
            <node name="pixelate">
                <parameter name="severity"     type="real" min="0"   max="0"/>
                <parameter name="start_pct"    type="real" min="0"   max="0"/>
                <parameter name="duration_pct" type="real" min="100" max="100"/>
                <constraint name="bounded" expressions=".\start_pct + .\duration_pct INFEQ 100"/>
            </node>

        </node>

    </node>

</root>
