<?xml version="1.0"?>
<!--
    trajectory_template.xml — Contraintes utilisateur pour TAF
    ==========================================================
    TAF (z3 solver) echantillonne des scenarios d'approche valides
    a partir de ces parametres et contraintes.

    L'utilisateur modifie les min/max/values selon ses besoins.
    TAF genere nb_test_cases scenarios (voir settings.xml).

    airport_runway : format "ICAO_RWY" (ex: "LFPO_06").
    Voir LARD/data/filtered_runways_database_Final.json pour la liste.
-->
<root name="test_case">

    <node name="scenario" nb_instances="1">

        <!-- ===== Parametres temporels / spatiaux ===== -->

        <parameter name="fps"
                   type="integer"
                   min="15"
                   max="15"/>

        <parameter name="segment_start_m"
                   type="real"
                   min="2000"
                   max="3000"/>

        <parameter name="segment_end_m"
                   type="real"
                   min="280"
                   max="280"/> <!-- 1000 -->

        <parameter name="ground_speed_kts"
                   type="real"
                   min="145" 
                   max="145"/>

        <!-- ===== Processus Ornstein-Uhlenbeck ===== -->

        <parameter name="turbulence_intensity"
                   type="real"
                   min="0"
                   max="1"/>

        <!-- ===== Vent ===== -->

        <parameter name="wind_speed_kts"
                   type="real"
                   min="0"
                   max="30"/>  <!-- 30 -->
  
        <parameter name="wind_direction_deg"
                   type="real"
                   min="0"
                   max="359"/>  <!-- 359 -->

        <!-- ===== Convergence finale ===== -->

        <parameter name="stabilization_distance_m"
                   type="real"
                   min="1000"
                   max="1500"/> <!-- 1500 -->

        <!-- ===== Piste cible (format ICAO_RWY) ===== -->

        <!-- Demo X-Plane : KPDX uniquement (Portland)
             Remettre les autres pistes avec la licence complete :
             LFPO_6;LFPO_24;LFPG_27L;LFPG_27R;LFPG_09L;LFPG_09R;LFBO_32L;LFBO_32R;EGLL_27L;EGLL_27R;CYYZ_24L;EFHK_4R;EKCH_4L;EDDF_25C;EDDF_07C;EHAM_18C;EHAM_27;LEBL_24L;LIRF_16R;LPPT_2;KATL_26L;KATL_8R;KLAX_24R;KLAX_25L;KDEN_34R;KJFK_22L;KJFK_31R;KORD_28C;KSFO_28R;WMKK_33;VHHH_07R;RJTT_22;YSSY_34R
        -->
        <parameter name="airport_runway"
                   type="string"
                   values="KPDX_10L"/> <!--KPDX_10L;KPDX_28R;KPDX_28L;KPDX_10R;KPDX_3;KPDX_21-->
                   

        <!-- ===== Effets meteo X-Plane 12 ===== -->
        <!--
            Effets meteo injectes via XPPython3 (plugin PI_lard_weather.py)
            pendant le rendu X-Plane 12. Ignores si renderer=ges.

            Meme pattern que les fautes capteur :
              {type}_severity  : severite [0.0, 1.0] — min="0" max="0" pour desactiver
              {type}_from_pct  : debut d'application en % de la trajectoire [0, 100]
              {type}_to_pct    : fin d'application en % de la trajectoire [0, 100]
                                 (0% = debut approche loin, 100% = pres de la piste)

            EFFETS DISPONIBLES ET TESTES SUR XP12 :
              - cloud  : nuages (severity → couverture 0-100%, type overcast)
                         Injectes via XPLMWeather API, apparaissent immediatement.
              - rain   : pluie (severity → precip_rate 0-1)
                         IMPORTANT : la pluie n'est visible que si visibility <= 10km.
                         Le pipeline force automatiquement la visibilite si rain actif.
                         Les nuages sont generes automatiquement par XP12 avec la pluie.
              - visibility : visibilite/brouillard (severity → 500m a 10km)
                         Fonctionne seul ou combine avec nuages/pluie.

            CONTRAINTE VISIBILITE :
              XP12 n'affiche pas la pluie au-dessus de ~10km de visibilite.
              Si rain est actif, la visibilite est automatiquement cappee a 10km.

            Les nuages et la pluie sont independants :
              - Nuages seuls : OK (cloud_severity > 0, rain_severity = 0)
              - Pluie seule  : OK (rain_severity > 0, XP12 genere ses propres nuages)
              - Les deux      : OK (les nuages manuels + pluie se combinent)
        -->

        <!-- Pluie : severity >= 0.8 recommande pour etre visible
             La visibilite est automatiquement reduite quand la pluie est active -->
        <parameter name="rain_severity"         type="real" min="0" max="0"/>
        <parameter name="rain_from_pct"          type="real" min="0" max="0"/>
        <parameter name="rain_to_pct"            type="real" min="100" max="100"/>

        <!-- Nuages : independants de la pluie, pour couverture nuageuse sans precipitation
             severity controle la couverture (0.2=few, 0.4=scattered, 0.7=broken, 1.0=overcast)
             Les nuages sont places a basse altitude (100-600m MSL) -->
        <parameter name="cloud_severity"        type="real" min="0" max="0"/>
        <parameter name="cloud_from_pct"         type="real" min="0" max="0"/>
        <parameter name="cloud_to_pct"           type="real" min="100" max="100"/>

        <!-- Visibilite / brouillard : severity controle la reduction de visibilite
             severity 0.0 = 50km (clair), 1.0 = 500m (brouillard epais)
             Fonctionne seul ou combine avec nuages/pluie -->
        <parameter name="visibility_severity"   type="real" min="0" max="0"/>
        <parameter name="visibility_from_pct"    type="real" min="0" max="0"/>
        <parameter name="visibility_to_pct"      type="real" min="100" max="100"/>

        <!-- Contraintes from < to -->
        <constraint name="rain_pct_order"
                    expressions="scenario[i]\rain_from_pct INF scenario[i]\rain_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="cloud_pct_order"
                    expressions="scenario[i]\cloud_from_pct INF scenario[i]\cloud_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="visibility_pct_order"
                    expressions="scenario[i]\visibility_from_pct INF scenario[i]\visibility_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>

        <!-- Contrainte XP12 : la pluie n'est visible que si visibility_severity > 0
             (le pipeline force automatiquement vis <= 10km si rain actif,
              mais si l'utilisateur veut controler la visibilite manuellement
              il doit activer visibility_severity quand rain_severity > 0) -->

        <!-- ===== Fautes capteur camera ===== -->
        <!--
            Chaque type de faute a 3 parametres :
              {type}_severity  : severite [0.0, 1.0] — mettre min="0" max="0" pour desactiver
              {type}_from_pct  : debut d'application en % de la trajectoire [0, 100]
              {type}_to_pct    : fin d'application en % de la trajectoire [0, 100]
                                 (0% = debut approche loin, 100% = pres de la piste)

            Pour activer une faute : mettre severity min/max > 0 et ajuster from/to.
            Plusieurs fautes se cumulent si leurs plages se chevauchent.
            TAF (z3) sample dans les plages min/max et valide les contraintes.
        -->



        <!-- ===== Bruits ===== -->

        <parameter name="gaussian_noise_severity"  type="real" min="0" max="0"/>
        <parameter name="gaussian_noise_from_pct"   type="real" min="0" max="0"/>
        <parameter name="gaussian_noise_to_pct"     type="real" min="100" max="100"/>

        <parameter name="shot_noise_severity"       type="real" min="0" max="0"/>
        <parameter name="shot_noise_from_pct"        type="real" min="0" max="0"/>
        <parameter name="shot_noise_to_pct"          type="real" min="100" max="100"/>

        <parameter name="salt_pepper_severity"      type="real" min="0" max="0"/>
        <parameter name="salt_pepper_from_pct"       type="real" min="0" max="0"/>
        <parameter name="salt_pepper_to_pct"         type="real" min="100" max="100"/>

        <parameter name="dead_pixels_severity"      type="real" min="0" max="0"/>
        <parameter name="dead_pixels_from_pct"       type="real" min="0" max="0"/>
        <parameter name="dead_pixels_to_pct"         type="real" min="100" max="100"/>

        <!-- ===== Flous ===== -->

        <parameter name="motion_blur_severity"      type="real" min="0" max="0"/>
        <parameter name="motion_blur_from_pct"       type="real" min="0" max="0"/>
        <parameter name="motion_blur_to_pct"         type="real" min="100" max="100"/>

        <parameter name="defocus_blur_severity"     type="real" min="0" max="0"/>
        <parameter name="defocus_blur_from_pct"      type="real" min="0" max="0"/>
        <parameter name="defocus_blur_to_pct"        type="real" min="100" max="100"/>

        <parameter name="rolling_shutter_severity"  type="real" min="0" max="0"/>
        <parameter name="rolling_shutter_from_pct"   type="real" min="0" max="0"/>
        <parameter name="rolling_shutter_to_pct"     type="real" min="100" max="100"/>

        <!-- ===== Exposition ===== -->

        <parameter name="overexposure_severity"     type="real" min="0" max="0"/>
        <parameter name="overexposure_from_pct"      type="real" min="0" max="0"/>
        <parameter name="overexposure_to_pct"        type="real" min="100" max="100"/>

        <parameter name="underexposure_severity"    type="real" min="0" max="0"/>
        <parameter name="underexposure_from_pct"     type="real" min="0" max="0"/>
        <parameter name="underexposure_to_pct"       type="real" min="100" max="100"/>

        <!-- ===== Optique ===== -->

        <parameter name="vignetting_severity"       type="real" min="0" max="0"/>
        <parameter name="vignetting_from_pct"        type="real" min="0" max="0"/>
        <parameter name="vignetting_to_pct"          type="real" min="100" max="100"/>

        <parameter name="chromatic_aberration_severity" type="real" min="0" max="0"/>
        <parameter name="chromatic_aberration_from_pct"  type="real" min="0" max="0"/>
        <parameter name="chromatic_aberration_to_pct"    type="real" min="100" max="100"/>

        <parameter name="radial_distortion_severity" type="real" min="0.2" max="0.2"/>
        <parameter name="radial_distortion_from_pct"  type="real" min="0" max="0"/>
        <parameter name="radial_distortion_to_pct"    type="real" min="100" max="100"/>

        <parameter name="lens_flare_severity"       type="real" min="0" max="0"/>
        <parameter name="lens_flare_from_pct"        type="real" min="0" max="0"/>
        <parameter name="lens_flare_to_pct"          type="real" min="100" max="100"/>

        <!-- ===== Artefacts ===== -->

        <parameter name="banding_severity"          type="real" min="0" max="0"/>
        <parameter name="banding_from_pct"           type="real" min="0" max="0"/>
        <parameter name="banding_to_pct"             type="real" min="100" max="100"/>

        <parameter name="jpeg_artifacts_severity"   type="real" min="0" max="0"/>
        <parameter name="jpeg_artifacts_from_pct"    type="real" min="0" max="0"/>
        <parameter name="jpeg_artifacts_to_pct"      type="real" min="100" max="100"/>

        <parameter name="color_shift_severity"      type="real" min="0" max="0"/>
        <parameter name="color_shift_from_pct"       type="real" min="0" max="0"/>
        <parameter name="color_shift_to_pct"         type="real" min="100" max="100"/>

        <!-- ===== Environnement / salissure ===== -->

        <parameter name="condensation_severity"     type="real" min="0" max="0"/>
        <parameter name="condensation_from_pct"      type="real" min="0" max="0"/>
        <parameter name="condensation_to_pct"        type="real" min="100" max="100"/>

        <parameter name="dirt_on_lens_severity"     type="real" min="0" max="0"/>
        <parameter name="dirt_on_lens_from_pct"      type="real" min="0" max="0"/>
        <parameter name="dirt_on_lens_to_pct"        type="real" min="100" max="100"/>

        <parameter name="fog_severity"              type="real" min="0" max="0"/>
        <parameter name="fog_from_pct"               type="real" min="0" max="0"/>
        <parameter name="fog_to_pct"                 type="real" min="100" max="100"/>

        <!-- ===== Transformations geometriques ===== -->

        <parameter name="zoom_blur_severity"        type="real" min="0" max="0"/>
        <parameter name="zoom_blur_from_pct"         type="real" min="0" max="0"/>
        <parameter name="zoom_blur_to_pct"           type="real" min="100" max="100"/>

        <parameter name="contrast_severity"         type="real" min="0" max="0"/>
        <parameter name="contrast_from_pct"          type="real" min="0" max="0"/>
        <parameter name="contrast_to_pct"            type="real" min="100" max="100"/>

        <parameter name="pixelate_severity"         type="real" min="0" max="0"/>
        <parameter name="pixelate_from_pct"          type="real" min="0" max="0"/>
        <parameter name="pixelate_to_pct"            type="real" min="100" max="100"/>

        <!-- Contraintes from < to pour chaque faute -->
        <constraint name="gaussian_noise_pct_order"
                    expressions="scenario[i]\gaussian_noise_from_pct INF scenario[i]\gaussian_noise_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="shot_noise_pct_order"
                    expressions="scenario[i]\shot_noise_from_pct INF scenario[i]\shot_noise_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="salt_pepper_pct_order"
                    expressions="scenario[i]\salt_pepper_from_pct INF scenario[i]\salt_pepper_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="dead_pixels_pct_order"
                    expressions="scenario[i]\dead_pixels_from_pct INF scenario[i]\dead_pixels_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="motion_blur_pct_order"
                    expressions="scenario[i]\motion_blur_from_pct INF scenario[i]\motion_blur_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="defocus_blur_pct_order"
                    expressions="scenario[i]\defocus_blur_from_pct INF scenario[i]\defocus_blur_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="rolling_shutter_pct_order"
                    expressions="scenario[i]\rolling_shutter_from_pct INF scenario[i]\rolling_shutter_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="overexposure_pct_order"
                    expressions="scenario[i]\overexposure_from_pct INF scenario[i]\overexposure_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="underexposure_pct_order"
                    expressions="scenario[i]\underexposure_from_pct INF scenario[i]\underexposure_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="vignetting_pct_order"
                    expressions="scenario[i]\vignetting_from_pct INF scenario[i]\vignetting_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="chromatic_aberration_pct_order"
                    expressions="scenario[i]\chromatic_aberration_from_pct INF scenario[i]\chromatic_aberration_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="radial_distortion_pct_order"
                    expressions="scenario[i]\radial_distortion_from_pct INF scenario[i]\radial_distortion_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="lens_flare_pct_order"
                    expressions="scenario[i]\lens_flare_from_pct INF scenario[i]\lens_flare_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="banding_pct_order"
                    expressions="scenario[i]\banding_from_pct INF scenario[i]\banding_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="jpeg_artifacts_pct_order"
                    expressions="scenario[i]\jpeg_artifacts_from_pct INF scenario[i]\jpeg_artifacts_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="color_shift_pct_order"
                    expressions="scenario[i]\color_shift_from_pct INF scenario[i]\color_shift_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="condensation_pct_order"
                    expressions="scenario[i]\condensation_from_pct INF scenario[i]\condensation_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="dirt_on_lens_pct_order"
                    expressions="scenario[i]\dirt_on_lens_from_pct INF scenario[i]\dirt_on_lens_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="fog_pct_order"
                    expressions="scenario[i]\fog_from_pct INF scenario[i]\fog_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="zoom_blur_pct_order"
                    expressions="scenario[i]\zoom_blur_from_pct INF scenario[i]\zoom_blur_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="contrast_pct_order"
                    expressions="scenario[i]\contrast_from_pct INF scenario[i]\contrast_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>
        <constraint name="pixelate_pct_order"
                    expressions="scenario[i]\pixelate_from_pct INF scenario[i]\pixelate_to_pct"
                    quantifiers="i" ranges="[0, 0]" types="forall"/>

        <!-- ===== Contraintes ===== -->

        <!-- Le debut d'approche doit etre plus loin que la fin -->
        <constraint name="start_gt_end"
                    expressions="scenario[i]\segment_start_m SUP scenario[i]\segment_end_m"
                    quantifiers="i"
                    ranges="[0, 0]"
                    types="forall"/>

        <!-- Marge entre stabilisation et fin d'approche :
             La zone de convergence doit etre assez large pour que
             la trajectoire ait le temps de se stabiliser naturellement.
             500m ≈ 6.7s a 145kts — temps realiste pour stabiliser.
             stab >= end + 500  -->
        <constraint name="stab_margin"
                    expressions="scenario[i]\stabilization_distance_m SUPEQ scenario[i]\segment_end_m + 500"
                    quantifiers="i"
                    ranges="[0, 0]"
                    types="forall"/>

        <!-- Marge entre debut d'approche et stabilisation :
             Il faut assez de trajectoire "libre" (deviations OU pleines)
             avant que la convergence ne commence.
             start >= stab + 500  -->
        <constraint name="start_margin"
                    expressions="scenario[i]\segment_start_m SUPEQ scenario[i]\stabilization_distance_m + 500"
                    quantifiers="i"
                    ranges="[0, 0]"
                    types="forall"/>

    </node>

</root>
